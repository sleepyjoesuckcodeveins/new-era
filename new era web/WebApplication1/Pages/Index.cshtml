@page
@model IndexModel
@{
    ViewData["Title"] = "Home page";
}

<div class="container-fluid px-0">
    <!-- Hero Intro -->
    <div class="bg-warm-gradient text-center py-5 mb-5 shadow-sm">
        <h1 class="display-4 fw-bold">Welcome to New Era Web</h1>
        <p class="lead">Fresh styles, bold colors, and exclusive deals.</p>
        <button class="btn btn-light fw-bold px-4 py-2 mt-2" style="color: var(--brand-orange);">Shop Now</button>
    </div>

    <div class="container">
        <!-- Section Header -->
        <div class="d-flex justify-content-between align-items-end mb-4">
            <h2 class="fw-semibold" style="border-left: 5px solid var(--brand-yellow); padding-left: 15px;">Latest Arrivals</h2>
            <p class="text-muted d-none d-md-block">Scroll to explore &rarr;</p>
        </div>

        <!-- Scrollable Product Row -->
        <div class="product-scroll-container">
            @if (Model.Products != null && Model.Products.Count > 0)
            {
                @foreach (var product in Model.Products)
                {
                    <div class="card product-card shadow-sm">
                        <div class="card-img-top bg-light d-flex align-items-center justify-content-center" style="height: 180px;">
                            <!-- Placeholder for Image -->
                            <i class="bi bi-box-seam display-4 text-muted"></i>
                        </div>
                        <div class="card-body">
                            <span class="badge rounded-pill mb-2" style="background-color: var(--brand-yellow); color: #333;">@product.Category</span>
                            <h5 class="card-title fw-bold">@product.Name</h5>
                            <p class="price-tag mb-0">$@product.Price.ToString("0.00")</p>
                            <button class="btn btn-outline-dark btn-sm w-100 mt-3">Add to Cart</button>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="alert alert-light border w-100 text-center">
                    No products found in our bright collection!
                </div>
            }
        </div>
        
        <!-- Bottom Section for Variety -->
        <div class="row mt-5 pt-5 border-top">
            <div class="col-md-6 mb-4">
                <div class="p-5 rounded-4 shadow-sm" style="background-color: var(--brand-yellow);">
                    <h3>Summer Sale</h3>
                    <p>Up to 50% off select orange items!</p>
                </div>
            </div>
            <div class="col-md-6 mb-4">
                <div class="p-5 rounded-4 shadow-sm text-white" style="background-color: var(--brand-coral);">
                    <h3>New Arrivals</h3>
                    <p>Check out the latest coral-themed tech.</p>
                </div>
            </div>
        </div>
    </div>
</div>
<style>
    /* Theme Colors */
    :root {
        --brand-coral: #ff7465;
        --brand-orange: #ffd500;
        --brand-yellow: #FFD700;
    }

    .bg-warm-gradient {
        background: linear-gradient(135deg, var(--brand-coral), var(--brand-orange));
        color: white;
    }

    /* Horizontal Scroll Container */
    .product-scroll-container {
        display: flex;
        flex-wrap: nowrap;
        overflow-x: auto;
        padding-bottom: 1.5rem;
        gap: 1.5rem;
        -webkit-overflow-scrolling: touch;
        scrollbar-width: thin;
        scrollbar-color: var(--brand-orange) transparent;
    }

    /* Card Customization */
    .product-card {
        flex: 0 0 auto;
        width: 280px; /* Adjust width to show 4-5 on large screens */
        border: none;
        transition: transform 0.3s ease;
        border-bottom: 4px solid var(--brand-yellow);
    }

    .product-card:hover {
        transform: translateY(-5px);
    }

    .price-tag {
        color: var(--brand-orange);
        font-weight: bold;
        font-size: 1.2rem;
    }

    /* Scrollbar Styling for Chrome/Safari */
    .product-scroll-container::-webkit-scrollbar {
        height: 8px;
    }
    .product-scroll-container::-webkit-scrollbar-thumb {
        background: var(--brand-orange);
        border-radius: 10px;
    }
</style>