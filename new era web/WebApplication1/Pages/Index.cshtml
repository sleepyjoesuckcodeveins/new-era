@page
@model IndexModel
@{
    ViewData["Title"] = "Home page";
}

<div class="container-fluid px-0">
    <!-- Compact Hero Intro -->
    <div class="bg-warm-gradient text-center py-4 mb-4 shadow-sm">
        <h1 class="h2 fw-bold">New Era Web</h1>
        <p class="opacity-75 small">Fresh finds. Bold deals.</p>
        <!-- Themed Button -->
        <button class="btn btn-sm px-4 fw-bold" style="background-color: var(--brand-yellow); color: #444;">
            View All Deals
        </button>
    </div>

    <div class="container">
        <h5 class="fw-bold mb-3 text-dark">Recently Added</h5>
        
        <!-- Scrolled Container with smaller items -->
        <div class="product-scroll-container">
            @if (Model.Products != null && Model.Products.Count > 0)
            {
                @foreach (var product in Model.Products)
                {
                    <div class="card product-card shadow-sm">
                        <div class="card-img-top bg-light d-flex align-items-center justify-content-center" style="height: 140px; border-radius: 12px 12px 0 0;">
                            <!-- Placeholder icon or image -->
                            <span class="text-muted small">Product Image</span>
                        </div>
                        <div class="card-body p-3">
                            <p class="text-uppercase mb-1" style="font-size: 0.7rem; color: var(--brand-orange); letter-spacing: 1px;">@product.Category</p>
                            <h6 class="card-title text-truncate mb-2">@product.Name</h6>
                            <div class="d-flex justify-content-between align-items-center">
                                <span class="price-text">$@product.Price.ToString("0.00")</span>
                                <button class="btn btn-brand-orange btn-sm rounded-circle">
                                    <i class="bi bi-plus"></i> +
                                </button>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="alert bg-white border w-100 text-center py-4">
                    <p class="mb-0 text-muted">Nothing here yet!</p>
                </div>
            }
        </div>

        <!-- Featured Section to break up the background -->
        <div class="mt-4 p-4 rounded-4 text-white shadow-sm" style="background: var(--brand-coral);">
            <div class="row align-items-center">
                <div class="col-8">
                    <h4 class="mb-1">Flash Sale</h4>
                    <p class="small mb-0">Don't miss out on today's orange-tagged items.</p>
                </div>
                <div class="col-4 text-end">
                    <button class="btn btn-outline-light btn-sm">Explore</button>
                </div>
            </div>
        </div>
    </div>
</div>
<style>
    :root {
        --brand-coral: #FF7F50;
        --brand-orange: #FF8C00;
        --brand-yellow: #FFD700;
        /* A soft, warm background to replace the "too white" look */
        --brand-bg: #FFF9F5; 
    }

    body {
        background-color: var(--brand-bg);
    }

    .bg-warm-gradient {
        background: linear-gradient(135deg, var(--brand-coral), var(--brand-orange));
        color: white;
    }

    /* Smaller, compact cards */
    .product-card {
        flex: 0 0 auto;
        width: 200px; /* Reduced from 280px */
        border: none;
        border-radius: 12px;
        transition: transform 0.2s ease;
        background-color: white;
    }

    .product-card:hover {
        transform: scale(1.03);
    }

    .product-scroll-container {
        display: flex;
        flex-wrap: nowrap;
        overflow-x: auto;
        padding: 10px 5px 20px 5px;
        gap: 1rem;
        scrollbar-width: none; /* Clean look for Firefox */
    }

    .product-scroll-container::-webkit-scrollbar {
        display: none; /* Clean look for Chrome/Safari */
    }

    .btn-brand-orange {
        background-color: var(--brand-orange);
        color: white;
        border: none;
    }

    .btn-brand-orange:hover {
        background-color: var(--brand-coral);
        color: white;
    }

    .price-text {
        color: var(--brand-coral);
        font-weight: 700;
    }
</style>